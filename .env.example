# UFMT Stats — Environment Variables
# Copie este arquivo para .env.local e preencha os valores.

# =============================================================================
# SUPABASE (produção)
# =============================================================================
# Em modo demo (sem essas duas vars), o site lê de data/seed.json.
# Para ativar Supabase Auth + persistência real no admin, defina ambas.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# =============================================================================
# ADMIN DEMO (somente modo demo)
# =============================================================================
# Senha usada APENAS quando Supabase NÃO está ativo (modo demo).
# Em produção (Supabase ativo), essa var é ignorada — o login passa pelo
# Supabase Auth (email + senha do usuário criado no dashboard).
#
# Default se vazia: "ufmt2024". Em produção, deixe vazio.

ADMIN_DEMO_PASSWORD=
